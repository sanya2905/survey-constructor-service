# ── Database ────────────────────────────────────────────────────────────────
# asyncpg URL used by SQLAlchemy and Alembic.
# When running via docker-compose use the service name as host:
DATABASE_URL=postgresql+asyncpg://survey:survey@survey-db:5432/survey_db
# For local dev outside compose:
# DATABASE_URL=postgresql+asyncpg://survey:survey@localhost:5433/survey_db

# ── Security ────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme

# JWT lifetime in minutes (default 1440 = 24 h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# When the parent application proxies requests, add its public origin here.
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── Registration ─────────────────────────────────────────────────────────────
# Set to false to disable the public POST /auth/register endpoint.
# Recommended: false in production; the parent app manages user provisioning.
REGISTRATION_OPEN=true

# ── Proxy authentication ─────────────────────────────────────────────────────
# Set to true ONLY when a trusted reverse-proxy / parent app sits in front
# and injects X-Forwarded-User and X-Forwarded-Role headers.
# NEVER enable this if this service is directly exposed to the internet.
PROXY_AUTH_ENABLED=false

# ── Subsystem identity ───────────────────────────────────────────────────────
# Returned by GET /api/v1/info so the parent app can identify this subsystem.
SUBSYSTEM_NAME=survey-constructor
SUBSYSTEM_VERSION=0.1.0

# ── Debug ───────────────────────────────────────────────────────────────────
DEBUG=false
